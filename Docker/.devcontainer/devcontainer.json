{
  "name": "Development Environment",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "eamodio.gitlens"
      ]
    }
  },

  "forwardPorts": [8080],
  "remoteUser": "vscode",

  "postCreateCommand": "pip3 install --upgrade pip"
}